# AI Generation Layer Environment Variables
# Copy this file to .env and fill in your actual values

# Flask dev server port (default 5001). Set another value if something else already uses it
# (e.g. another Node/Express app often binds 5000/5001 and you would see the wrong site).
PORT=5001

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Optional AI Generation Configuration
AI_GEN_MODEL_NAME=gemini-1.5-flash
AI_GEN_TEMPERATURE=0.7
AI_GEN_MAX_TOKENS=1024
AI_GEN_LOG_LEVEL=INFO
AI_GEN_CACHE_RESPONSES=false
AI_GEN_MAX_GENERATION_TIME=30.0

# Notification Layer Configuration
# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_sendgrid_from_email_here
SENDGRID_FROM_NAME=AdsCompetitor

# Notification Settings
NOTIFICATION_ENABLED=true
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_TIMEOUT=30.0

# Firebase (optional - for login/signup)
# 1. Create a project at https://console.firebase.google.com
# 2. Add a Web app and copy the config below (Project settings > General > Your apps)
# 3. Enable Email/Password sign-in: Authentication > Sign-in method > Email/Password > Enable
# 4. For server session: Project settings > Service accounts > Generate new private key → save JSON, set path below
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123
# Server-side login (Firebase Admin): use ONE of these — not both.
# - Deploy (Render, Railway, Fly, etc.): set FIREBASE_CREDENTIALS_JSON to the full service account JSON on ONE line.
#   Run: python scripts/firebase_json_to_env.py path/to/serviceAccountKey.json
#   Copy the "one-line JSON" into the host's env UI as the value for FIREBASE_CREDENTIALS_JSON (do not commit it).
#   Leave FIREBASE_CREDENTIALS_PATH unset on the server.
# - Local dev: either FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json OR the same FIREBASE_CREDENTIALS_JSON line in .env.
# FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Stripe (required for paid plans - users must select plan and pay to use generator)
# Dashboard: https://dashboard.stripe.com/apikeys and Products → create products → copy Price IDs
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_PRICE_STARTER=price_xxx_starter_monthly
STRIPE_PRICE_PRO=price_xxx_pro_monthly
# Webhook secret from Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Endpoint to register: https://yourdomain.com/api/stripe-webhook  (events: checkout.session.completed)
STRIPE_WEBHOOK_SECRET=
# Production (Render, etc.):
# - TRUST_PROXY_HEADERS=1  (required so request.url_root is https://your-domain, not http://internal)
# - SESSION_COOKIE_SECURE=1  (HTTPS only)
# - PUBLIC_APP_URL=https://www.yourdomain.com  MUST match the exact host users open (www vs non-www).
#   If unsure, omit PUBLIC_APP_URL and rely on TRUST_PROXY_HEADERS + your Render custom domain.
# Empty STRIPE_SUCCESS_URL / STRIPE_CANCEL_URL = app builds .../payment-success and .../choose-plan from the above.
# Optional overrides (same host as your site; success path only — code appends ?session_id=...)
# STRIPE_SUCCESS_URL=https://www.yourdomain.com/payment-success
# STRIPE_CANCEL_URL=https://www.yourdomain.com/choose-plan
PUBLIC_APP_URL=
TRUST_PROXY_HEADERS=
SESSION_COOKIE_SECURE=

# Admin panel: comma-separated list of admin emails (they get admin without password)
ADMIN_EMAILS=admin@example.com
# Optional: shared admin password. If set, any logged-in user can access /admin after entering this password.
ADMIN_PASSWORD=adsgen