# AI Generation Layer Environment Variables
# Copy this file to .env and fill in your actual values

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Optional AI Generation Configuration
AI_GEN_MODEL_NAME=gemini-1.5-flash
AI_GEN_TEMPERATURE=0.7
AI_GEN_MAX_TOKENS=1024
AI_GEN_LOG_LEVEL=INFO
AI_GEN_CACHE_RESPONSES=false
AI_GEN_MAX_GENERATION_TIME=30.0

# Notification Layer Configuration
# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_sendgrid_from_email_here
SENDGRID_FROM_NAME=AdsCompetitor

# Notification Settings
NOTIFICATION_ENABLED=true
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_TIMEOUT=30.0

# Firebase (optional - for login/signup)
# 1. Create a project at https://console.firebase.google.com
# 2. Add a Web app and copy the config below (Project settings > General > Your apps)
# 3. Enable Email/Password sign-in: Authentication > Sign-in method > Email/Password > Enable
# 4. For server session: Project settings > Service accounts > Generate new private key → save JSON, set path below
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123
# Server-side login: use ONE of these:
# - Local: path to service account JSON file
# FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json
# - Render/Heroku: paste the entire JSON as one line (no line breaks)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Stripe (required for paid plans - users must select plan and pay to use generator)
# Dashboard: https://dashboard.stripe.com/apikeys and Products → create products → copy Price IDs
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_PRICE_STARTER=price_xxx_starter_monthly
STRIPE_PRICE_PRO=price_xxx_pro_monthly
STRIPE_SUCCESS_URL=http://localhost:5001/payment-success
STRIPE_CANCEL_URL=http://localhost:5001/choose-plan

# Admin panel: comma-separated list of admin emails (they get admin without password)
ADMIN_EMAILS=admin@example.com
# Optional: shared admin password. If set, any logged-in user can access /admin after entering this password.
ADMIN_PASSWORD=adsgen